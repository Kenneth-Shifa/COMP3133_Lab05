PORT=4000

# MongoDB Atlas - use either DB_CONNECTION_STRING or the separate variables below
# DB_CONNECTION_STRING=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/dbname?retryWrites=true&w=majority

DB_USER_NAME=your_username
DB_PASSWORD=your_password
CLUSTER_ID=your_cluster_id
DB_NAME=your_database_name
